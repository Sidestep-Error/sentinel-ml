# Copy to .env and fill in actual values. Never commit .env.

# MongoDB connection to sentinel-upload-api's data (read-only recommended)
MONGODB_URI=mongodb://localhost:28017
MONGODB_DB=sentinel
MONGODB_DB_UPLOAD=sentinel_upload

# Ollama (lokal LLM)
# LLM är avstängd som standard. Den driftsatta vägen använder klassiska
# modeller och anropar bara Ollama när detta uttryckligen aktiveras.
LLM_ENABLED=false
# Lokal host-installation:
OLLAMA_HOST=http://localhost:11434
# Docker Compose-service:
# OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=3.0

# MLflow tracking (optional)
MLFLOW_TRACKING_URI=file:./mlruns

# Random seed for reproducibility
SENTINEL_ML_SEED=42

# MalwareBazaar (gratis nyckel på https://bazaar.abuse.ch/api/)
MALWAREBAZAAR_API_KEY=

# Path roots
DATA_DIR=./data
MODELS_DIR=./models_store

# Hash-bridge: threat-reports JSONL whose hash-IOCs blir known-malicious-setet.
# Lämna tom för att stänga av (matchning returnerar då alltid "ingen träff").
KNOWN_MALICIOUS_HASHES_PATH=
