# Copy to .env and fill in actual values. Never commit .env.

# MongoDB connection to sentinel-upload-api's data (read-only recommended)
MONGODB_URI=mongodb://localhost:28017
MONGODB_DB=sentinel
MONGODB_DB_UPLOAD=sentinel_upload

# Ollama (local LLM) — used by Spar A LLM-baserade IOC-extraktion.
# LLM_ENABLED is off by default: the deployed path runs classical models and
# only calls Ollama when this is set to true (e.g. local demo).
LLM_ENABLED=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=3.0

# MLflow tracking (optional)
MLFLOW_TRACKING_URI=file:./mlruns

# Random seed for reproducibility
SENTINEL_ML_SEED=42

# MalwareBazaar (gratis nyckel på https://bazaar.abuse.ch/api/)
MALWAREBAZAAR_API_KEY=

# Path roots
DATA_DIR=./data
MODELS_DIR=./models_store
